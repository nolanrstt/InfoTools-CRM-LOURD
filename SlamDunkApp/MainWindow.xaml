<Window x:Class="SlamDunkApp.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="SlamDunk - Accueil" 

        Height="800" Width="1400"

        MinHeight="700" MinWidth="1250"

        ResizeMode="CanResize"

        WindowStartupLocation="CenterScreen"

        Background="White">



    <Window.Resources>

        <Style x:Key="NavButtonStyle" TargetType="Button">

            <Setter Property="Height" Value="38"/>

            <Setter Property="Width" Value="110"/>

            <Setter Property="Background" Value="White"/>

            <Setter Property="Foreground" Value="#333"/>

            <Setter Property="FontWeight" Value="Bold"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Margin" Value="10,0,0,0"/>

            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}" CornerRadius="15">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>



    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <Border Grid.Row="0" 

                HorizontalAlignment="Stretch" 

                Height="85" 

                Margin="15,10,15,0" 

                Background="#FFFFF8D6" 

                BorderBrush="#EEE" 

                BorderThickness="1"

                CornerRadius="20">

            <Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">

                    <Image Source="/logo-infotools.png" 
           Height="233" 
           Margin="0,0,25,0" 
           Stretch="Uniform" 
           VerticalAlignment="Center" Width="170"/>

                    <Border x:Name="ProfilUserBorder" 
            Background="#FFFFF8D6" 
            CornerRadius="12" 
            Padding="8,5,15,5" 
            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="17" Background="#FFED2F36" Margin="0,0,10,0">
                                <TextBlock x:Name="txtUserInitial" Text="A" 
                           Foreground="White" FontWeight="Bold" FontSize="16" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtUserName" Text="Chargement..." Foreground="Black" FontWeight="Bold" FontSize="13"/>
                                <TextBlock x:Name="txtUserRole" Text="Manager" Foreground="Red" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button x:Name="BtnAccueil" Content="Accueil" Style="{StaticResource NavButtonStyle}" Click="BtnAccueil_Click"/>
                    <Button x:Name="BtnProduits" Content="Produits" Style="{StaticResource NavButtonStyle}" Click="BtnProduits_Click"/>
                    <Button x:Name="BtnClients" Content="Clients" Style="{StaticResource NavButtonStyle}" Click="BtnClients_Click"/>
                    <Button x:Name="BtnRendezVous" Content="Rendez-vous" Style="{StaticResource NavButtonStyle}" Click="BtnRendezVous_Click"/>

                    <Button x:Name="BtnFactures" Content="Factures" Style="{StaticResource NavButtonStyle}" Click="BtnFactures_Click"/>

                    <Button x:Name="BtnConnexion" Content="Déconnexion" Style="{StaticResource NavButtonStyle}" Background="#FFED2F36" Foreground="White" Click="BtnConnexion_Click"/>
                </StackPanel>

            </Grid>

        </Border>



        <ContentControl x:Name="MainContent" 

                        Grid.Row="1"

                        HorizontalAlignment="Stretch" 

                        VerticalAlignment="Stretch"

                        Margin="15"/>

    </Grid>

</Window>