<UserControl x:Class="SlamDunkApp.FacturesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="FactureGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="AlternatingRowBackground" Value="#FFEEEEEE"/>
            <Setter Property="RowBackground" Value="#FFF5F5F5"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFF0F0F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FFF0F0F0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.2"/>
        </Grid.Effect>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFF5F5F5" CornerRadius="20" Margin="0,0,15,0" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📦 Catalogue Produits" FontSize="20" FontWeight="Bold" Foreground="#222" Margin="0,0,0,15"/>

                <DataGrid x:Name="DtgProduitsDispo" Grid.Row="1" Style="{StaticResource FactureGridStyle}" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                        <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="60" />
                        <DataGridTextColumn Header="Prix" Binding="{Binding Prix, StringFormat={}{0:C}}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="Qté :" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtQuantite" Width="50" Height="30" Text="1" TextAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,15,0"/>

                    <Button x:Name="BtnAjouterPanier" Content="🛒 Ajouter au panier" Width="150" Height="40" 
                            Background="#FFF7C13C" Foreground="#333" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                            Click="BtnAjouterPanier_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFF7C13C" CornerRadius="20" Margin="0,0,0,15" Padding="20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👤 Client facturé :" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbClients" Width="300" Height="35" FontSize="14" VerticalContentAlignment="Center" DisplayMemberPath="NomComplet" SelectionChanged="CmbClients_SelectionChanged"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFF5F5F5" CornerRadius="20" Padding="20" Margin="0,0,15,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="🧾 Contenu de la Facture" FontSize="20" FontWeight="Bold" Foreground="#222" Margin="0,0,0,15"/>

                        <DataGrid x:Name="DtgPanier" Grid.Row="1" Style="{StaticResource FactureGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produit" Binding="{Binding NomProduit}" Width="*" />
                                <DataGridTextColumn Header="Qté" Binding="{Binding Quantite}" Width="50" />
                                <DataGridTextColumn Header="Prix U." Binding="{Binding PrixUnitaire, StringFormat={}{0:C}}" Width="80" />
                                <DataGridTextColumn Header="S-Total" Binding="{Binding SousTotal, StringFormat={}{0:C}}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="2" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnViderPanier" Grid.Column="0" Content="🗑️ Vider" Width="100" Height="40" 
                                    Background="#6C757D" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="BtnViderPanier_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="TOTAL :" FontSize="20" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTotal" Text="0,00 €" FontSize="22" FontWeight="ExtraBold" Foreground="#D9534F" Margin="0,0,15,0" VerticalAlignment="Center"/>

                                <Button x:Name="BtnValiderFacture" Content="✅ VALIDER" Width="140" Height="45" 
                                        Background="#28A745" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                        Click="BtnValiderFacture_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#FFF5F5F5" CornerRadius="20" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="📜 Historique Client" FontSize="18" FontWeight="Bold" Foreground="#222" Margin="0,0,0,15"/>

                        <DataGrid x:Name="DtgHistorique" Grid.Row="1" Style="{StaticResource FactureGridStyle}" MouseDoubleClick="DtgHistorique_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="N°" Binding="{Binding IdFacture}" Width="40" />
                                <DataGridTextColumn Header="Date" Binding="{Binding DateFacture, StringFormat={}{0:dd/MM/yyyy}}" Width="*" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalTTC, StringFormat={}{0:C}}" Width="75" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>