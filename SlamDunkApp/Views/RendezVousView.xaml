<UserControl x:Class="SlamDunkApp.RendezVousView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="BtnAjouterStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFED2F36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="25">
                            <Border.Effect>
                                <DropShadowEffect Color="#999" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D91E25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFF7C13C" CornerRadius="20" Margin="0,0,20,0">
            <Border.Effect>
                <DropShadowEffect Color="#CCC" BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel Margin="25">
                
                <TextBlock Text="Nouveau Rendez-vous" Foreground="White" FontWeight="Bold" FontSize="20" Margin="0,0,0,30" TextAlignment="Center"/>
                <Border Height="15"/>

                <TextBlock Text="Assigné à" Foreground="White" FontWeight="SemiBold" Margin="5,0,0,5"/>
                <ComboBox x:Name="CboUtilisateur" 
          Height="40" 
          VerticalContentAlignment="Center" 
          FontSize="14" 
          BorderThickness="0" 
          DisplayMemberPath="NomComplet" 
          SelectedValuePath="Id"
          Foreground="Black" 
          Background="White"
          Padding="10,0" SelectionChanged="CboUtilisateur_SelectionChanged">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <Border Height="15"/>
                <TextBlock Text="Client" Foreground="White" FontWeight="SemiBold" Margin="5,0,0,5"/>

                <ComboBox x:Name="CboClient" 
                          Height="40" 
                          VerticalContentAlignment="Center" 
                          FontSize="14" 
                          BorderThickness="0" 
                          DisplayMemberPath="NomComplet"
                          SelectedValuePath="IdClient"
                          Foreground="Black" 
                          Background="White"
                          Padding="10,0">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <Border Height="15"/>

                <TextBlock Text="Jour" Foreground="White" FontWeight="SemiBold" Margin="5,0,0,5"/>

                <ComboBox x:Name="CboJour" 
                          Height="40" 
                          VerticalContentAlignment="Center" 
                          FontSize="14" 
                          BorderThickness="0"
                          Foreground="Black"
                          Background="White"
                          Padding="10,0" SelectionChanged="CboJour_SelectionChanged">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="Lundi"/>
                    <ComboBoxItem Content="Mardi"/>
                    <ComboBoxItem Content="Mercredi"/>
                    <ComboBoxItem Content="Jeudi"/>
                    <ComboBoxItem Content="Vendredi"/>
                </ComboBox>

                <Border Height="15"/>

                <TextBlock Text="Heure de début" Foreground="White" FontWeight="SemiBold" Margin="5,0,0,5"/>

                <ComboBox x:Name="CboHeure" 
                          Height="40" 
                          VerticalContentAlignment="Center" 
                          FontSize="14" 
                          BorderThickness="0"
                          Foreground="Black"
                          Background="White"
                          Padding="10,0">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="08:00"/>
                    <ComboBoxItem Content="09:00"/>
                    <ComboBoxItem Content="10:00"/>
                    <ComboBoxItem Content="11:00"/>
                    <ComboBoxItem Content="12:00"/>
                    <ComboBoxItem Content="13:00"/>
                    <ComboBoxItem Content="14:00"/>
                    <ComboBoxItem Content="15:00"/>
                    <ComboBoxItem Content="16:00"/>
                    <ComboBoxItem Content="17:00"/>
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Button x:Name="BtnAjouter" Content="AJOUTER" Style="{StaticResource BtnAjouterStyle}" Width="110" Click="BtnAjouter_Click" Margin="0,0,10,0"/>
                    <Button x:Name="BtnModifier" Content="MODIFIER" Style="{StaticResource BtnAjouterStyle}" Width="110" Background="#6C757D" Click="BtnModifier_Click" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Performances (RDV)" Foreground="#999" FontWeight="Bold" FontSize="14" Margin="5,0,0,5"/>

            <Border Grid.Row="1" Background="#FFF5F5F5" CornerRadius="15" Margin="0,0,0,20" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="#DDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
                <lvc:CartesianChart Series="{Binding SeriesCollection}" LegendLocation="None">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding Labels}" Separator="{x:Static lvc:DefaultAxes.CleanSeparator}"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis MinValue="0" ShowLabels="True"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Planning Hebdomadaire" Foreground="#333" FontWeight="Bold" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Border Width="12" Height="12" Background="#FFF7C13C" CornerRadius="6" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="RDV Confirmé" VerticalAlignment="Center" Foreground="#888" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&lt;" Width="30" Height="30" Click="BtnSemainePrecedente_Click"
                            Background="White" BorderBrush="#DDD" FontWeight="Bold" Margin="0,0,10,0"/>

                    <TextBlock x:Name="TxtSemaineEnCours" Text="Semaine du ..." VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#555" Margin="0,0,10,0"/>

                    <Button Content="&gt;" Width="30" Height="30" Click="BtnSemaineSuivante_Click"
                            Background="White" BorderBrush="#DDD" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="3" Background="#FFF5F5F5" CornerRadius="15" Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="#DDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="GridAgenda" ShowGridLines="True">
                        <Grid.Resources>
                            <Style TargetType="Grid">
                                <Setter Property="Background" Value="#FFF5F5F5"/>
                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                            </Style>
                            <Style TargetType="Line">
                                <Setter Property="Stroke" Value="#EEE"/>
                            </Style>
                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="1" Text="LUN" FontWeight="Bold" Foreground="#FFED2F36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="MAR" FontWeight="Bold" Foreground="#FFED2F36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="MER" FontWeight="Bold" Foreground="#FFED2F36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="JEU" FontWeight="Bold" Foreground="#FFED2F36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="VEN" FontWeight="Bold" Foreground="#FFED2F36" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Text="08:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="2" Text="09:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="3" Text="10:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="4" Text="11:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="5" Text="12:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="6" Text="13:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="7" Text="14:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="8" Text="15:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="9" Text="16:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                        <TextBlock Grid.Row="10" Text="17:00" FontSize="11" Foreground="#AAA" VerticalAlignment="Top" Margin="5"/>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>