<UserControl x:Class="SlamDunkApp.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="White"  
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="LoginInputStyle" TargetType="{x:Type Control}">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Width="450" 
                Padding="30"
                Background="White"
                CornerRadius="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <Image Source="/logo-infotools.png"
                       Height="200"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="Connexion"
                           FontSize="32"
                           FontWeight="ExtraBold"
                           Foreground="#FFED2F36"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Label Content="Identifiant"
                       FontWeight="SemiBold"
                       Foreground="Black"
                       Margin="0,0,0,5"/>

                <Border x:Name="IdBorder" 
                        CornerRadius="10"
                        BorderBrush="#EEE"
                        BorderThickness="2"
                        Background="White"
                        Margin="0,0,0,20">
                    <TextBox x:Name="TxtIdentifiant"
                             VerticalContentAlignment="Center"
                             Background="Transparent">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource LoginInputStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#FFED2F36"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <Label Content="Mot de passe"
                       FontWeight="SemiBold"
                       Foreground="Black"
                       Margin="0,0,0,5"/>

                <Grid Margin="0,0,0,25">
                    <Border x:Name="PasswordBorder"
                            CornerRadius="10"
                            BorderBrush="#EEE"
                            BorderThickness="2"
                            Background="White">

                        <PasswordBox x:Name="TxtMotDePasse"
                                     Padding="8,6,35,6"
                                     VerticalContentAlignment="Center">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox" BasedOn="{StaticResource LoginInputStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Tag" Value="Focused"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>
                    </Border>

                    <TextBox x:Name="TxtMotDePasseVisible"
                             Padding="8,6,35,6"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"
                             Style="{StaticResource LoginInputStyle}"/>

                    <Button x:Name="BtnTogglePassword"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Content="👁"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#777"
                            Cursor="Hand"
                            Click="BtnTogglePassword_Click"/>
                </Grid>

                <TextBlock x:Name="TxtErreur"
                           Text=""
                           Foreground="#FFED2F36"
                           FontWeight="Bold"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"
                           Visibility="Collapsed"/>

                <Button x:Name="BtnConnexion"
                        Content="Se connecter"
                        Height="50"
                        FontSize="18"
                        FontWeight="ExtraBold"
                        Foreground="#333"
                        Background="#FFF7C13C"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnConnexion_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FFED2F36"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>