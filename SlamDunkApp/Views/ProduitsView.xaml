<UserControl x:Class="SlamDunkApp.ProduitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="ProduitGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="AlternatingRowBackground" Value="#FFEEEEEE"/>
            <Setter Property="RowBackground" Value="#FFF5F5F5"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFF0F0F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FFF0F0F0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.2"/>
        </Grid.Effect>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFF7C13C" CornerRadius="20" Margin="0,0,15,0" Padding="15" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,20" Text="🔍 Filtrer les produits" />

                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Rechercher un produit :" Foreground="White" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtRecherche" Grid.Row="1" Margin="0,5,0,15" Height="28" Padding="5"
                             BorderBrush="#FFF7C13C" BorderThickness="1" TextChanged="TxtRecherche_TextChanged" />

                    <TextBlock Grid.Row="2" Text="Catégorie :" Foreground="White" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbCategorie" Grid.Row="3" Margin="0,5,0,15" Height="28"
                              Foreground="#333" Background="White"
                              BorderBrush="#FFF7C13C" BorderThickness="1"
                              SelectedIndex="0" SelectionChanged="CmbCategorie_SelectionChanged">
                        <ComboBoxItem Content="Tous les produits"/>
                        <ComboBoxItem Content="Matériel"/>
                        <ComboBoxItem Content="Logiciel"/>
                    </ComboBox>
                </Grid>

                <Button x:Name="BtnReinitialiser" Content="🔄 Réinitialiser" Height="35"
                        Background="#6C757D" Foreground="White" FontWeight="Bold" BorderThickness="0" 
                        Cursor="Hand" Margin="0,15,0,0" Click="BtnReinitialiser_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#FFF5F5F5" CornerRadius="20" Margin="0,0,15,0" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📦 Liste des produits" FontSize="20" FontWeight="Bold" Foreground="#222" Margin="0,0,0,15"/>

                <DataGrid x:Name="DataGridProduits" Grid.Row="1" Style="{StaticResource ProduitGridStyle}"
                          SelectionChanged="DataGridProduits_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                        <DataGridTextColumn Header="Catégorie" Binding="{Binding Categorie}" Width="*" />
                        <DataGridTextColumn Header="Prix (€)" Binding="{Binding Prix}" Width="*" />
                        <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFF5F5F5" CornerRadius="20" Margin="0,0,0,15" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
                </Border.Effect>

                <StackPanel x:Name="GridDetails">
                    <TextBlock Text="📝 Détails du produit" FontSize="20" FontWeight="Bold" Foreground="#222" Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nom :" Margin="0,0,10,10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtNom" Grid.Row="0" Grid.Column="1" Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Background="White"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Catégorie :" Margin="0,0,10,10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtCategorie" Grid.Row="1" Grid.Column="1" Text="{Binding Categorie, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Background="White"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Prix (€) :" Margin="0,0,10,10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtPrix" Grid.Row="2" Grid.Column="1" Text="{Binding Prix, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Background="White"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Stock :" Margin="0,0,10,10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtStock" Grid.Row="3" Grid.Column="1" Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Background="White"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="BtnSauvegarder" Content="💾 Sauvegarder" Width="130" Height="40" Background="#FFF7C13C" Foreground="#333" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Click="BtnSauvegarder_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnAnnuler" Content="✖ Annuler" Width="130" Height="40" Margin="10,0,0,0" Background="#6C757D" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Click="BtnAnnuler_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnAjouter" Content="➕ Ajouter" Width="110" Height="40" Background="#FFF7C13C" Foreground="#333"
                        FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand" Click="BtnAjouter_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnModifier" Content="✏️ Modifier" Width="110" Height="40" Background="White" Foreground="#333"
                        FontWeight="Bold" BorderBrush="#FFF7C13C" BorderThickness="2" Margin="0,0,10,0" Cursor="Hand" Click="BtnModifier_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="15" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnSupprimer" Content="🗑️ Suppr." Width="110" Height="40" Background="#FFF7C13C" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSupprimer_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>